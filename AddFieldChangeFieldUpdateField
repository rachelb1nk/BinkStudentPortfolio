# Define change fields for the Update field function
changeFields = ['StreetName','StreetAddrNoZip']

# Update field
# BEWARE: Below is only set up for instances where there is a number at the end
with arcpy.da.UpdateCursor(coffee_table, changeFields) as cursor:
# Split the field into different strings, prepping for removal 
    for row in cursor:
        existing_value = row[0]
        if existing_value:
            parts = existing_value.split()
# Replace the string at the end of the field
# Only if the string is a number
# This won't remove zipcode placed anywhere else within the field
            if parts[-1].replace("-", "").isdigit():
              parts = parts[:-1]

            row[1] = " ".join(parts)

# Make sure to update the row to join everything back together and have a clean output
            cursor.updateRow(row)
            print(row)
