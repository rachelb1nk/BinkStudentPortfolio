# Preeisting fields to be analyzed
# These fields will inform the output placed into new fields
fields = ["Gold", "Silver", "Nickel"]

# Set accumulators and counters so things are adequately defined 
# And so that a starting point has been determined

gold_total = 0
silver_total = 0
nickel_total = 0
row_count = 0

# Count rows and calc totals

with arcpy.da.SearchCursor(fc,fields) as cursor:
    for row in cursor:
